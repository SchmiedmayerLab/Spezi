# Swift Package Manager
Package.resolved
*.xcodeproj
# Ignore .swiftpm, but keep shared schemes (e.g. the Spezi-Tests test-plan host scheme) tracked.
.swiftpm/*
!.swiftpm/xcode
.swiftpm/xcode/*
!.swiftpm/xcode/xcshareddata
.swiftpm/xcode/xcshareddata/*
!.swiftpm/xcode/xcshareddata/xcschemes
# Track only the Spezi-Tests host scheme; ignore the per-target schemes Xcode auto-generates.
.swiftpm/xcode/xcshareddata/xcschemes/*
!.swiftpm/xcode/xcshareddata/xcschemes/Spezi-Tests.xcscheme
.build
.xcodebuild
.derivedData
coverage.lcov
*.xcresult

# IDE related folders
.idea

# Xcode User settings
xcuserdata/

# Other files
.DS_Store
.env

# Documentation generation
*.doccarchive
docs/

# UITests Project
!UITests.xcodeproj

__pycache__/

# local working clones for the monorepo migration
.incoming/
